          {% endfor %}
        </div>
        <div class="project-card__links">
          <a href="{{ project.url }}" class="btn pink-btn project-card__link" target="_blank">Visit Project</a>
        </div>
        {% if project.insight %}
        <blockquote class="project-card__insight">
          <p>"{{ project.insight }}"</p>
          {% if project.insightSource %}<cite>— {{ project.insightSource }}</cite>{% endif %}
