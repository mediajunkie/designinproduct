---
layout: layouts/base.njk
title: "Book a Consultation - Design in Product"
activePage: contact
ogTitle: "Work with Design in Product"
ogDescription: "Book a consultation with Christian Crumlish to transform your product organization"
---

<!-- Hero start -->
<div class="consultation-hero">
  <div class="consultation-hero__content">
    <h1 class="h1">Let's Work Together</h1>
    <p class="h2 consultation-hero__description">Ready to learn how to lead empowered product teams that deliver meaningful value to the lives of real people? Let's talk about how I can help transform your product organization.</p>
  </div>
</div>
<!-- Hero end -->

<!-- Consultation Form start -->
<div class="consultation-form-section">
  <div class="consultation-form-wrapper">
    <p class="consultation-form__intro">Thanks for getting in touch. Let's start by collecting your contact information.</p>

    <form id="consultationForm" class="consultation-form" action="https://docs.google.com/forms/d/e/1FAIpQLScxSOXahlPOIcyJ5DdpE6X0wqyfXkULJt05o59mWQ8x5WPXzA/formResponse" method="POST" target="hidden_iframe">

      <div class="form-group-row">
        <div class="form-group optional">
          <label for="firstName" class="form-label">First Name <span class="optional-text">(optional)</span></label>
          <input type="text" id="firstName" name="entry.519090293" class="form-input" placeholder="Jane">
        </div>
        <div class="form-group optional">
          <label for="lastName" class="form-label">Last Name <span class="optional-text">(optional)</span></label>
          <input type="text" id="lastName" name="entry.602738624" class="form-input" placeholder="Doe">
        </div>
      </div>

      <div class="form-group optional">
        <label for="email" class="form-label">Email <span class="optional-text">(optional)</span></label>
        <input type="email" id="email" name="entry.1418754594" class="form-input" placeholder="jane@company.com">
      </div>

      <div class="form-group optional">
        <label for="linkedin" class="form-label">LinkedIn profile or personal website <span class="optional-text">(optional)</span></label>
        <input type="url" id="linkedin" name="entry.1656529754" class="form-input" placeholder="https://linkedin.com/in/yourname">
      </div>

      <div class="form-group-row">
        <div class="form-group optional">
          <label for="company" class="form-label">Company Name <span class="optional-text">(optional)</span></label>
          <input type="text" id="company" name="entry.271565640" class="form-input" placeholder="Acme Corp">
        </div>
        <div class="form-group optional">
          <label for="companyWebsite" class="form-label">Company Website <span class="optional-text">(optional)</span></label>
          <input type="url" id="companyWebsite" name="entry.1854120733" class="form-input" placeholder="https://acmecorp.com">
        </div>
      </div>

      <div class="form-group optional">
        <label for="teamSize" class="form-label">Product Team Size <span class="optional-text">(optional)</span></label>
        <select id="teamSize" name="entry.471001496" class="form-input form-select">
          <option value="">Choose an option...</option>
          <option value="Just me">Just me</option>
          <option value="2-5 people">2-5 people</option>
          <option value="6-10 people">6-10 people</option>
          <option value="11-25 people">11-25 people</option>
          <option value="26-50 people">26-50 people</option>
          <option value="50+ people">50+ people</option>
        </select>
      </div>

      <div class="form-group optional">
        <label for="struggles" class="form-label">What are you currently struggling with? <span class="optional-text">(optional)</span></label>
        <textarea id="struggles" name="entry.23293699" class="form-textarea" placeholder="Tell me about your current challenges with product strategy, team alignment, execution, or anything else that's keeping you up at night..."></textarea>
        <p class="form-help-text">This helps me understand how I can best support you</p>
      </div>

      <div class="form-submit-section">
        <button type="submit" class="btn pink-btn consultation-form__submit">Send Message</button>
        <p class="form-privacy-text">Christian will be in touch within two working days.</p>
      </div>

    </form>
  </div>
</div>
<!-- Consultation Form end -->

<!-- What Happens Next start -->
<div class="consultation-next-steps">
  <h3 class="h3">What happens next?</h3>
  <div class="consultation-next-steps__list">
    <div class="consultation-step">
      <div class="consultation-step__number">1</div>
      <div class="consultation-step__content">
        <h4 class="consultation-step__title">Quick Response</h4>
        <p class="consultation-step__description">I'll review your message and respond within two working days with initial thoughts and next steps.</p>
      </div>
    </div>
    <div class="consultation-step">
      <div class="consultation-step__number">2</div>
      <div class="consultation-step__content">
        <h4 class="consultation-step__title">Discovery Call</h4>
        <p class="consultation-step__description">We'll schedule a 30-minute call to discuss your challenges and explore how I can help.</p>
      </div>
    </div>
    <div class="consultation-step">
      <div class="consultation-step__number">3</div>
      <div class="consultation-step__content">
        <h4 class="consultation-step__title">Custom Proposal</h4>
        <p class="consultation-step__description">Based on our conversation, I'll create a tailored proposal for how we can work together.</p>
      </div>
    </div>
  </div>
</div>
<!-- What Happens Next end -->

<!-- Hidden iframe for form submission -->
<iframe name="hidden_iframe" id="hidden_iframe" style="display:none;"></iframe>

{% block scripts %}
<script>
  document.getElementById('consultationForm').addEventListener('submit', function(e) {
    var submitButton = document.querySelector('.consultation-form__submit');
    submitButton.textContent = 'Sending...';
    submitButton.disabled = true;
    setTimeout(function() {
      window.location.href = '/consultation-thank-you/';
    }, 2000);
  });
</script>
{% endblock %}
